# ─── LLM & Embedding ───────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Reranking ─────────────────────────────────────────
COHERE_API_KEY=your-cohere-key-here

# ─── Vector Store (ChromaDB Cloud) ─────────────────────
CHROMA_API_KEY=ck-your-chromadb-cloud-api-key
CHROMA_TENANT=your-tenant-id
CHROMA_DATABASE=ask-docs
CHROMA_COLLECTION_NAME=ask-my-docs

# ─── BM25 Index ───────────────────────────────────────
BM25_INDEX_PATH=./data/bm25-index.json

# ─── API Server ───────────────────────────────────────
PORT=3000
API_KEY=your-secret-api-key-here

# ─── Evaluation Thresholds ────────────────────────────
FAITHFULNESS_THRESHOLD=0.85
ANSWER_RELEVANCY_THRESHOLD=0.80
CONTEXT_PRECISION_THRESHOLD=0.75
CONTEXT_RECALL_THRESHOLD=0.70

# ─── Evaluation Paths ────────────────────────────────
EVAL_DATASET_PATH=./data/eval/golden-dataset.json
EVAL_OUTPUT_PATH=./data/eval/results.json

# ─── Monitoring & Observability (Langfuse) ────────────────
# Get these from https://langfuse.com → Project Settings → API Keys
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_BASE_URL=https://cloud.langfuse.com
