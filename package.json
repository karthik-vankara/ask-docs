{
  "name": "ask-my-docs",
  "version": "1.0.0",
  "description": "Production RAG application with hybrid retrieval, cross-encoder reranking, citation enforcement, and CI-gated evaluation",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/api/server.ts",
    "start": "node dist/api/server.js",
    "ingest": "tsx scripts/ingest.ts",
    "evaluate": "tsx scripts/evaluate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ scripts/ --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@langchain/openai": "^0.3.0",
    "@langfuse/otel": "^4.6.1",
    "@langfuse/tracing": "^4.6.1",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "chromadb": "^1.9.2",
    "cohere-ai": "^7.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-handler": "^1.2.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
